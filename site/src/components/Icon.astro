    | 'lock'
    | 'clipboard'
    | 'gesture'
    | 'terminal'
    | 'source'
    | 'globe'
    | 'waveform'
    | 'github'
    | 'fdroid'
    | 'obtainium'
    | 'download'
    | 'play'
    | 'book'
    | 'code'
    | 'arrow-right'
    | 'sparkles'
    | 'chip'
    | 'check'
