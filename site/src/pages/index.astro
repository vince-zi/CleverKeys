---
import BaseLayout from '../layouts/BaseLayout.astro'
import SwipeHero from '../components/SwipeHero.svelte'
import InstallTabs from '../components/InstallTabs.svelte'
import FeatureCard from '../components/FeatureCard.astro'
import Icon from '../components/Icon.astro'
import { site, features, bundledLanguages, downloadableLanguages, stats } from '../lib/site'
---

<BaseLayout title={`${site.name} — ${site.tagline}`}>
  <!-- HERO -->
  <section class="relative overflow-hidden pt-12 pb-24 sm:pt-20">
    <!-- ambient grid -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-[1] mask-fade-b opacity-40">
      <svg width="100%" height="100%" class="text-white/5">
        <defs>
          <pattern id="grid" width="48" height="48" patternUnits="userSpaceOnUse">
            <path d="M 48 0 L 0 0 0 48" fill="none" stroke="currentColor" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)"/>
      </svg>
    </div>

    <div class="container-x grid items-center gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-7">
        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 text-xs font-medium text-[color:var(--color-violet-200)]">
          <span class="inline-flex h-1.5 w-1.5 rounded-full bg-[color:var(--color-teal)] shadow-[0_0_12px_#2dd4bf]"></span>
          v1.3 — Media clipboard, profiles, short-swipe customization
        </div>
        <h1 class="mt-5 font-display text-5xl font-bold leading-[1.05] tracking-tight sm:text-6xl lg:text-[4.25rem]">
          <span class="gradient-text">Neural gesture typing.</span>
          <br />
          <span class="text-white">Open source. On-device.</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-7 text-white/70">
          CleverKeys is an Android keyboard with a real transformer decoder running in your pocket — not in someone else's datacenter. 208 customizable swipe gestures, unlimited clipboard, and eleven languages.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a class="btn-primary" href={site.fdroid} target="_blank" rel="noopener noreferrer">
            <Icon name="fdroid" class="h-4 w-4" /> Install from F-Droid
          </a>
          <a class="btn-secondary" href="/demo/">
            <Icon name="play" class="h-4 w-4" /> Try the web demo
          </a>
          <a class="btn-secondary" href={site.repo} target="_blank" rel="noopener noreferrer">
            <Icon name="github" class="h-4 w-4" /> Star on GitHub
          </a>
        </div>

        <div class="mt-8 flex flex-wrap gap-2">
          <span class="chip">Android 8+</span>
          <span class="chip">100% Kotlin</span>
          <span class="chip">ONNX · XNNPACK</span>
          <span class="chip">GPL-3.0</span>
          <span class="chip">No network perms</span>
        </div>
      </div>

      <div class="relative lg:col-span-5">
        <div aria-hidden="true" class="absolute -inset-10 -z-[1] rounded-full bg-[color:var(--color-violet-600)]/15 blur-3xl"></div>
        <SwipeHero client:visible />
      </div>
    </div>
  </section>

  <!-- STATS RIBBON -->
  <section aria-label="By the numbers" class="relative -mt-6">
    <div class="container-x">
      <div class="hairline h-px" aria-hidden="true"></div>
      <dl class="grid grid-cols-2 divide-white/5 py-6 text-center md:grid-cols-4 md:divide-x">
        {stats.map((s) => (
          <div class="py-2">
            <dt class="text-[11px] font-semibold uppercase tracking-widest text-white/50">{s.label}</dt>
            <dd class="mt-2 font-display text-3xl font-bold tracking-tight">
              <span class="gradient-text">{s.value}</span>
            </dd>
          </div>
        ))}
      </dl>
      <div class="hairline h-px" aria-hidden="true"></div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="py-24" aria-labelledby="features-heading">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-[color:var(--color-violet-200)]">Why CleverKeys</p>
        <h2 id="features-heading" class="mt-3 font-display text-4xl font-bold tracking-tight">
          The only open-source keyboard with a <span class="gradient-text">public ML pipeline</span>.
        </h2>
        <p class="mt-4 text-white/65">Every layer of the stack — model, training data, tokenizer, app — is inspectable, reproducible, and yours.</p>
      </div>

      <div class="mt-14 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => <FeatureCard feature={f} />)}
      </div>
    </div>
  </section>

  <!-- INSTALL / QUICK START -->
  <section class="py-20" aria-labelledby="install-heading" id="install">
    <div class="container-x grid items-start gap-12 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <p class="text-xs font-semibold uppercase tracking-widest text-[color:var(--color-violet-200)]">Get it</p>
        <h2 id="install-heading" class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">
          Ship it to your phone in under a minute.
        </h2>
        <p class="mt-4 text-white/65">
          Choose a distribution channel. All releases are the same signed APK — reproducible builds mean you can verify the binary matches the source.
        </p>
        <ul class="mt-6 space-y-2.5 text-sm">
          <li class="flex items-start gap-2"><Icon name="check" class="mt-0.5 h-4 w-4 text-[color:var(--color-teal)]" /> Signed, reproducible release APK</li>
          <li class="flex items-start gap-2"><Icon name="check" class="mt-0.5 h-4 w-4 text-[color:var(--color-teal)]" /> Works offline immediately after install</li>
          <li class="flex items-start gap-2"><Icon name="check" class="mt-0.5 h-4 w-4 text-[color:var(--color-teal)]" /> No permissions beyond the Android IME contract</li>
        </ul>
      </div>

      <div class="min-w-0 lg:col-span-7">
        <InstallTabs client:visible />
        <p class="mt-3 text-xs text-white/45">Tip: after installing, head to <span class="font-mono text-white/70">Settings → Languages &amp; input → Keyboards</span> and set CleverKeys as active.</p>
      </div>
    </div>
  </section>

  <!-- LANGUAGES -->
  <section class="py-20" aria-labelledby="lang-heading">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-[color:var(--color-violet-200)]">Multi-language</p>
        <h2 id="lang-heading" class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">
          Eleven languages. Two active at once.
        </h2>
        <p class="mt-4 text-white/65">
          Primary + secondary language detection so code-switching doesn't require mode switching.
        </p>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        <div class="surface rounded-2xl p-6">
          <h3 class="font-display text-lg font-semibold text-white">Bundled with the APK</h3>
          <p class="mt-1 text-sm text-white/55">Ship-ready. No downloads.</p>
          <div class="mt-5 grid grid-cols-2 gap-2 text-sm">
            {bundledLanguages.map((lang) => (
              <span class="rounded-lg border border-white/5 bg-white/[0.03] px-3 py-2 text-white/85">
                {lang}
              </span>
            ))}
          </div>
        </div>
        <div class="surface rounded-2xl p-6">
          <h3 class="font-display text-lg font-semibold text-white">Language packs</h3>
          <p class="mt-1 text-sm text-white/55">Fetched on demand from the signed release.</p>
          <div class="mt-5 grid grid-cols-2 gap-2 text-sm">
            {downloadableLanguages.map((lang) => (
              <span class="rounded-lg border border-white/5 bg-white/[0.03] px-3 py-2 text-white/85">
                {lang}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DEMO CTA -->
  <section class="py-24" aria-labelledby="demo-heading">
    <div class="container-x">
      <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-[color:var(--color-violet-800)]/35 via-[color:var(--color-ink-700)] to-[color:var(--color-ink-800)] p-10 sm:p-14">
        <div aria-hidden="true" class="pointer-events-none absolute -right-20 -top-24 h-72 w-72 rounded-full bg-[color:var(--color-violet-500)]/25 blur-3xl"></div>
        <div aria-hidden="true" class="pointer-events-none absolute -left-24 bottom-0 h-72 w-72 rounded-full bg-[color:var(--color-teal)]/10 blur-3xl"></div>

        <div class="grid items-center gap-10 md:grid-cols-2">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-[color:var(--color-violet-200)]">Try it in the browser</p>
            <h2 id="demo-heading" class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">
              The same neural decoder, <span class="gradient-text">running in WebAssembly</span>.
            </h2>
            <p class="mt-4 text-white/70">
              No install. No account. No upload. Draw a word and watch the beam search unfold client-side.
            </p>
            <div class="mt-6">
              <a href="/demo/" class="btn-primary">
                <Icon name="play" class="h-4 w-4" /> Launch web demo
              </a>
            </div>
          </div>
          <div class="space-y-3">
            <div class="surface flex items-center gap-3 rounded-xl px-4 py-3">
              <Icon name="chip" class="h-5 w-5 text-[color:var(--color-violet-200)]" />
              <div><div class="text-sm font-semibold text-white">ONNX + XNNPACK</div><div class="text-xs text-white/55">Same quantized weights that ship in the APK.</div></div>
            </div>
            <div class="surface flex items-center gap-3 rounded-xl px-4 py-3">
              <Icon name="waveform" class="h-5 w-5 text-[color:var(--color-violet-200)]" />
              <div><div class="text-sm font-semibold text-white">Beam-search decoding</div><div class="text-xs text-white/55">See top-k candidates update in real time.</div></div>
            </div>
            <div class="surface flex items-center gap-3 rounded-xl px-4 py-3">
              <Icon name="lock" class="h-5 w-5 text-[color:var(--color-violet-200)]" />
              <div><div class="text-sm font-semibold text-white">Runs offline after first load</div><div class="text-xs text-white/55">Model caches to your browser storage.</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DOCS QUICKLINKS -->
  <section class="pb-24" aria-labelledby="docs-heading">
    <div class="container-x">
      <div class="flex items-end justify-between gap-6">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-[color:var(--color-violet-200)]">Documentation</p>
          <h2 id="docs-heading" class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">Go deeper</h2>
        </div>
        <a href="/wiki/" class="link-quiet hidden items-center gap-1 text-sm font-semibold sm:inline-flex">
          All guides <Icon name="arrow-right" class="h-4 w-4" />
        </a>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-3">
        <a href="/wiki/getting-started/installation" class="group surface relative overflow-hidden rounded-2xl p-6 transition hover:border-[color:var(--color-violet-500)]/40">
          <div class="flex items-center gap-3 text-[color:var(--color-violet-200)]"><Icon name="book" class="h-5 w-5" /><span class="text-xs font-semibold uppercase tracking-widest">User guide</span></div>
          <h3 class="mt-3 font-display text-lg font-semibold text-white">Install, enable, and set up</h3>
          <p class="mt-1 text-sm text-white/65">Ten-minute walkthrough from nothing to swipe-typing.</p>
          <span class="mt-4 inline-flex items-center gap-1 text-sm text-[color:var(--color-violet-200)] transition group-hover:text-white">Open <Icon name="arrow-right" class="h-4 w-4" /></span>
        </a>
        <a href="/specs/" class="group surface relative overflow-hidden rounded-2xl p-6 transition hover:border-[color:var(--color-violet-500)]/40">
          <div class="flex items-center gap-3 text-[color:var(--color-violet-200)]"><Icon name="code" class="h-5 w-5" /><span class="text-xs font-semibold uppercase tracking-widest">Technical specs</span></div>
          <h3 class="mt-3 font-display text-lg font-semibold text-white">Architecture &amp; data model</h3>
          <p class="mt-1 text-sm text-white/65">Transformer details, clipboard v4 schema, gesture pipeline.</p>
          <span class="mt-4 inline-flex items-center gap-1 text-sm text-[color:var(--color-violet-200)] transition group-hover:text-white">Open <Icon name="arrow-right" class="h-4 w-4" /></span>
        </a>
        <a href={site.mlRepo} target="_blank" rel="noopener noreferrer" class="group surface relative overflow-hidden rounded-2xl p-6 transition hover:border-[color:var(--color-violet-500)]/40">
          <div class="flex items-center gap-3 text-[color:var(--color-violet-200)]"><Icon name="sparkles" class="h-5 w-5" /><span class="text-xs font-semibold uppercase tracking-widest">Training pipeline</span></div>
          <h3 class="mt-3 font-display text-lg font-semibold text-white">CleverKeys-ML</h3>
          <p class="mt-1 text-sm text-white/65">Datasets, training loop, evaluation, export. Reproduce every weight.</p>
          <span class="mt-4 inline-flex items-center gap-1 text-sm text-[color:var(--color-violet-200)] transition group-hover:text-white">View repo <Icon name="arrow-right" class="h-4 w-4" /></span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
