<?xml version="1.0" encoding="utf-8"?>
<!-- FileProvider paths for sharing GIF files via content:// URIs.
     Required for commitContent() to insert animated WebP GIFs into apps. -->
<paths>
    <!-- Full animated GIFs in app-internal storage (GifAssetManager.cacheDir) -->
    <files-path name="gifs_full" path="gifs/full/" />
    <!-- GIF sharing cache (Gif.getCacheFile uses cacheDir/gifs/) -->
    <cache-path name="gifs_cache" path="gifs/" />
    <!-- GIF pack storage -->
    <files-path name="gif_packs" path="gif_packs/" />
</paths>
